<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/rootScroll"
    android:background="#0f0f0f"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Nombre del agente -->
        <TextView
            android:id="@+id/tvAgentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agente"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed" />

        <TextView
            android:id="@+id/tvAgentRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VENDEDOR"
            android:textColor="#888888"
            android:textSize="12sp"
            android:letterSpacing="0.15" />

        <!-- ● EN VIVO badge (animated pulse) -->
        <LinearLayout
            android:id="@+id/liveContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/badge_live"
            android:padding="6dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone">

            <View
                android:id="@+id/liveDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_green"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvLive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EN VIVO"
                android:textColor="#22c55e"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-condensed" />
        </LinearLayout>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_background"
            android:padding="32dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS DESACTIVADO"
                android:textColor="#888888"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvCoords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--.----- , ---.-----"
                android:textColor="#666666"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 🔒 Admin lock message (hidden by default) -->
        <LinearLayout
            android:id="@+id/lockMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/badge_lock"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 Modo supervisado — solo el admin puede detener"
                android:textColor="#aaaaaa"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Botón Toggle -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  INICIAR TRACKING"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:backgroundTint="@color/naranja"
            android:layout_marginBottom="12dp" />

        <!-- Botón Ver Mapa -->
        <Button
            android:id="@+id/btnMap"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🗺️  VER MAPA Y CLIENTES"
            android:textColor="@color/naranja_claro"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:backgroundTint="#1a1a1a"
            android:layout_marginBottom="16dp" />

        <!-- Info Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView android:id="@+id/tvSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/naranja_claro" android:textSize="28sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="KM/H" android:textColor="#666" android:textSize="10sp" android:letterSpacing="0.15" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView android:id="@+id/tvBattery" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textColor="@color/naranja_claro" android:textSize="28sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BATERÍA" android:textColor="#666" android:textSize="10sp" android:letterSpacing="0.15" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView android:id="@+id/tvUpdates" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/naranja_claro" android:textSize="28sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ENVÍOS" android:textColor="#666" android:textSize="10sp" android:letterSpacing="0.15" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView android:id="@+id/tvAccuracy" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textColor="@color/naranja_claro" android:textSize="28sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PRECISIÓN (M)" android:textColor="#666" android:textSize="10sp" android:letterSpacing="0.15" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ubify v2.0 · ArrazolApp"
            android:textColor="#333333"
            android:textSize="10sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
